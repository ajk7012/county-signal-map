# Provider: openai or local
TRANSCRIBE_PROVIDER=openai

# OpenAI transcription provider
# OpenAI API keys start with sk-. Do not paste a Google AIza key here.
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Local transcription provider
# Recommended local default: faster-whisper large-v3-turbo.
LOCAL_TRANSCRIBE_MODEL=large-v3-turbo
LOCAL_TRANSCRIBE_DEVICE=auto
LOCAL_TRANSCRIBE_COMPUTE_TYPE=default
LOCAL_TRANSCRIBE_LANGUAGE=en
LOCAL_TRANSCRIBE_PYTHON=python

BROADCASTIFY_API_KEY=
COUNTY_PRESET=greene-oh
PUBLIC_SAFETY_DELAY_MINUTES=0
PORT=8787
COMPATIBILITY_PORT=5173

# For a certificate-chain problem, prefer NODE_EXTRA_CA_CERTS=C:\path\to\root-cert.pem.
# Local testing fallback only:
# NODE_TLS_REJECT_UNAUTHORIZED=0
